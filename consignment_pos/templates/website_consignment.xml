<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ═══════════════════════════════════════════════════════════════════════
     CONSIGNMENT LANDING PAGE  —  /consignment
     ═══════════════════════════════════════════════════════════════════════ -->
<template id="website_consignment_home" name="Consignment Home">
    <t t-call="website.layout">
        <!-- Include Google Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;800&amp;display=swap" rel="stylesheet"/>
        <style>
            :root {
                --primary-color: #2D3142;
                --accent-color: #EF8354;
                --bg-light: #F9F9F9;
                --text-main: #2D3142;
                --text-muted: #7A7C87;
                --font-family: 'Outfit', sans-serif;
            }
            .consignment-home {
                font-family: var(--font-family);
                background-color: var(--bg-light);
                color: var(--text-main);
                overflow-x: hidden;
            }
            /* Hero Section */
            .hero-section {
                position: relative;
                padding: 120px 0 100px;
                background: linear-gradient(135deg, #1f1c2c 0%, #928DAB 100%);
                color: #fff;
                text-align: center;
                overflow: hidden;
                z-index: 1;
            }
            /* Add some decorative animated blobs */
            .hero-section::before, .hero-section::after {
                content: '';
                position: absolute;
                border-radius: 50%;
                filter: blur(80px);
                z-index: -1;
                animation: float 10s infinite alternate ease-in-out;
            }
            .hero-section::before {
                width: 400px;
                height: 400px;
                background: rgba(239, 131, 84, 0.4);
                top: -100px;
                left: -100px;
            }
            .hero-section::after {
                width: 500px;
                height: 500px;
                background: rgba(45, 49, 66, 0.4);
                bottom: -150px;
                right: -100px;
                animation-delay: -5s;
            }
            @keyframes float {
                0% { transform: translate(0, 0); }
                100% { transform: translate(40px, 40px); }
            }
            .hero-title {
                font-size: 4rem;
                font-weight: 800;
                letter-spacing: -1px;
                margin-bottom: 20px;
                line-height: 1.1;
                text-shadow: 0 4px 20px rgba(0,0,0,0.1);
            }
            .hero-subtitle {
                font-size: 1.25rem;
                font-weight: 400;
                opacity: 0.9;
                max-width: 600px;
                margin: 0 auto 40px;
                line-height: 1.6;
            }
            .btn-primary-custom {
                background: #EF8354;
                color: #fff;
                padding: 16px 40px;
                border-radius: 50px;
                font-weight: 700;
                font-size: 1.1rem;
                text-decoration: none;
                transition: all 0.3s ease;
                display: inline-block;
                box-shadow: 0 10px 20px rgba(239, 131, 84, 0.3);
                border: 2px solid #EF8354;
            }
            .btn-primary-custom:hover {
                background: transparent;
                color: #EF8354;
                box-shadow: 0 5px 10px rgba(239, 131, 84, 0.2);
                transform: translateY(-2px);
            }
            .btn-secondary-custom {
                background: transparent;
                color: #fff;
                padding: 16px 40px;
                border-radius: 50px;
                font-weight: 700;
                font-size: 1.1rem;
                text-decoration: none;
                transition: all 0.3s ease;
                display: inline-block;
                border: 2px solid rgba(255,255,255,0.6);
            }
            .btn-secondary-custom:hover {
                background: #fff;
                color: #2D3142;
                border-color: #fff;
                transform: translateY(-2px);
            }
            /* Section Headers */
            .section-header {
                text-align: center;
                margin-bottom: 60px;
            }
            .section-title {
                font-size: 2.5rem;
                font-weight: 800;
                color: var(--primary-color);
                margin-bottom: 15px;
                position: relative;
                display: inline-block;
            }
            .section-title::after {
                content: '';
                position: absolute;
                bottom: -5px;
                left: 50%;
                transform: translateX(-50%);
                width: 60px;
                height: 4px;
                background: var(--accent-color);
                border-radius: 2px;
            }
            .section-subtitle {
                font-size: 1.1rem;
                color: var(--text-muted);
            }
            /* Designer Cards */
            .designer-card {
                background: #fff;
                border-radius: 16px;
                padding: 30px 20px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.03);
                transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                text-align: center;
                height: 100%;
                position: relative;
                overflow: hidden;
            }
            .designer-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            }
            .designer-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 6px;
                background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
                opacity: 0;
                transition: opacity 0.3s ease;
            }
            .designer-card:hover::before {
                opacity: 1;
            }
            .designer-avatar {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                background: linear-gradient(135deg, #f6f8fa, #e9ecef);
                color: var(--primary-color);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2rem;
                font-weight: 800;
                margin: 0 auto 20px;
                box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            }
            .designer-name {
                font-weight: 700;
                font-size: 1.2rem;
                color: var(--primary-color);
                margin-bottom: 8px;
            }
            .designer-specialty {
                font-size: 0.9rem;
                color: var(--text-muted);
                margin-bottom: 15px;
                font-weight: 500;
            }
            .designer-stats {
                display: inline-block;
                background: rgba(239, 131, 84, 0.1);
                color: var(--accent-color);
                padding: 6px 12px;
                border-radius: 20px;
                font-size: 0.8rem;
                font-weight: 700;
            }
            /* Product Cards */
            .product-card {
                background: #fff;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0,0,0,0.03);
                transition: all 0.3s ease;
                height: 100%;
            }
            .product-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            }
            .product-img-wrap {
                position: relative;
                overflow: hidden;
                background: #f8f9fa;
            }
            .product-img {
                width: 100%;
                height: 280px;
                object-fit: cover;
                transition: transform 0.6s ease;
            }
            .product-card:hover .product-img {
                transform: scale(1.05);
            }
            .product-badge {
                position: absolute;
                top: 15px;
                right: 15px;
                background: #FFF;
                color: var(--primary-color);
                padding: 6px 12px;
                border-radius: 30px;
                font-size: 0.75rem;
                font-weight: 700;
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
                z-index: 2;
            }
            .product-info {
                padding: 24px;
            }
            .product-designer {
                font-size: 0.8rem;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 8px;
                display: block;
                font-weight: 600;
            }
            .product-title {
                font-size: 1.15rem;
                font-weight: 700;
                color: var(--primary-color);
                margin-bottom: 12px;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
            .product-price-row {
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-top: 1px solid #eee;
                padding-top: 16px;
                margin-top: 16px;
            }
            .product-price {
                font-size: 1.25rem;
                font-weight: 800;
                color: var(--accent-color);
            }
            .product-action {
                font-size: 0.9rem;
                color: var(--primary-color);
                font-weight: 700;
                display: flex;
                align-items: center;
                gap: 5px;
                transition: color 0.2s;
            }
            .product-card:hover .product-action {
                color: var(--accent-color);
            }
        </style>
        <div id="wrap" class="consignment-home">

            <!-- Premium Hero Banner -->
            <section class="hero-section" style="padding: 160px 0 140px; background: radial-gradient(circle at 10% 20%, rgba(31,28,44,1) 0%, rgba(56,52,73,1) 50%, rgba(31,28,44,1) 100%);">
                <div class="container" style="position:relative; z-index:10;">
                    <div class="row align-items-center">
                        <div class="col-lg-7 text-center text-lg-start">
                            <span class="badge" style="background:rgba(239, 131, 84, 0.2); color:#EF8354; padding:8px 16px; border-radius:30px; margin-bottom:20px; font-weight:700; font-size:0.9rem;">
                                NEW: Apply to Sell With Us ✨
                            </span>
                            <h1 class="hero-title" style="font-size: 4.5rem; text-align: left;">
                                Elevated <br/><span style="color:#EF8354;">Consignment.</span>
                            </h1>
                            <p class="hero-subtitle" style="text-align: left; margin: 0 0 40px; font-size:1.3rem;">
                                Seamlessly connecting independent designers with mindful shoppers. Discover exclusive pieces or become a partner and sell directly through our integrated Omni-Channel POS.
                            </p>
                            <div class="d-flex gap-3 flex-wrap justify-content-center justify-content-lg-start">
                                <a href="/consignment/shop" class="btn-primary-custom" style="padding: 18px 45px;">
                                    Shop Collection
                                </a>
                                <a href="/designer/apply" class="btn-secondary-custom" style="padding: 18px 45px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
                                    Apply as Designer
                                </a>
                            </div>
                        </div>
                        <div class="col-lg-5 d-none d-lg-block">
                            <!-- Glassmorphism Card -->
                            <div style="background:rgba(255,255,255,0.05); backdrop-filter: blur(20px); border:1px solid rgba(255,255,255,0.1); border-radius:24px; padding:40px; box-shadow: 0 20px 50px rgba(0,0,0,0.3); transform: rotate(3deg); transition: transform 0.5s ease;" onmouseover="this.style.transform='rotate(0deg) scale(1.02)'" onmouseout="this.style.transform='rotate(3deg)'">
                                <h3 style="font-weight:800; font-size:2rem; margin-bottom:15px; color:#fff;">Omni-Channel Live</h3>
                                <p style="color:rgba(255,255,255,0.8); font-size:1.1rem; line-height:1.6; margin-bottom:25px;">
                                    When you list a product here, it instantly syncs to our In-Store POS. Sell anywhere, everywhere, zero hassle.
                                </p>
                                <a href="/designers" style="color:#EF8354; font-weight:700; text-decoration:none; font-size:1.1rem; border-bottom:2px solid #EF8354; padding-bottom:5px;">Explore Our Curators →</a>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Interactive Connectivity Section -->
            <section style="padding: 80px 0; background: #fff; border-bottom:1px solid #f1f1f1;">
                <div class="container">
                    <div class="row align-items-center text-center text-md-start">
                        <div class="col-md-4 mb-4 mb-md-0">
                            <div style="font-size: 3rem; margin-bottom:15px; color:var(--primary-color);">🌍</div>
                            <h4 style="font-weight:800;">Fully Synced System</h4>
                            <p class="text-muted">Website orders instantly deduct from our live POS inventory.</p>
                        </div>
                        <div class="col-md-4 mb-4 mb-md-0 border-start border-end border-light">
                            <div style="font-size: 3rem; margin-bottom:15px; color:var(--accent-color);">🤝</div>
                            <h4 style="font-weight:800;">Designer Portal</h4>
                            <p class="text-muted">Submit your products online, track payouts, and raise disputes.</p>
                        </div>
                        <div class="col-md-4">
                            <div style="font-size: 3rem; margin-bottom:15px; color:var(--primary-color);">📍</div>
                            <h4 style="font-weight:800;">Craft Origins</h4>
                            <p class="text-muted">Explore our interactive map to discover regional craftsmen.</p>
                            <a href="/craft-map" style="color:var(--accent-color); font-weight:700; text-decoration:none;">View Map →</a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Featured Designers -->
            <section style="padding: 100px 0; background: #fafafa;">
                <div class="container">
                    <div class="section-header">
                        <h2 class="section-title">Featured Craftspeople</h2>
                        <p class="section-subtitle">Supporting independent artisans and sustainable fashion</p>
                    </div>
                    <div class="row g-4 justify-content-center">
                        <t t-foreach="featured_designers" t-as="d">
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <a t-attf-href="/designers/{{ d.id }}" style="text-decoration:none; color:inherit; display:block; height:100%;">
                                    <div class="designer-card">
                                        <t t-if="d.image_512">
                                            <img t-attf-src="/web/image/res.partner/{{ d.id }}/image_512" 
                                                 class="designer-avatar" style="object-fit:cover;border:2px solid #EEE;" t-att-alt="d.name"/>
                                        </t>
                                        <t t-else="">
                                            <div class="designer-avatar">
                                                <t t-esc="d.name[0].upper()"/>
                                            </div>
                                        </t>
                                        <div class="designer-name">
                                            <t t-esc="d.name"/>
                                        </div>
                                        <t t-if="d.designer_specialty">
                                            <div class="designer-specialty">
                                                <t t-esc="d.designer_specialty"/>
                                            </div>
                                        </t>
                                        <div class="designer-stats">
                                            <t t-esc="d.website_product_count"/> Curated Items
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </t>
                        <t t-if="not featured_designers">
                            <div class="col-12 text-center text-muted" style="font-size:1.1rem; padding:40px 0;">
                                No designers featured at the moment.
                            </div>
                        </t>
                    </div>
                    <div class="text-center mt-5">
                        <a href="/designers" class="btn-secondary-custom" style="color:var(--primary-color); border-color:var(--primary-color);">
                            Meet All Designers
                        </a>
                    </div>
                </div>
            </section>

            <!-- Call to Action Banner -->
            <section style="padding: 100px 0; background: var(--primary-color); color:#fff; text-align:center;">
                <div class="container">
                    <h2 style="font-weight:800; font-size:3rem; margin-bottom:20px;">Ready to share your creations?</h2>
                    <p style="font-size:1.2rem; opacity:0.9; max-width:600px; margin:0 auto 40px;">
                        Join our network of premium consignors. Submit your profile, let us review your craft, and start selling directly to our in-store and online customer base.
                    </p>
                    <a href="/designer/apply" class="btn-primary-custom" style="font-size:1.2rem; padding: 20px 50px;">
                        Apply to Consign With Us
                    </a>
                </div>
            </section>

            <!-- New Arrivals -->
            <section style="padding: 100px 0;">
                <div class="container">
                    <div class="section-header">
                        <h2 class="section-title">Latest Arrivals</h2>
                        <p class="section-subtitle">Freshly listed independent designer pieces</p>
                    </div>
                    <div class="row g-4">
                        <t t-foreach="new_arrivals" t-as="p">
                            <div class="col-lg-3 col-md-4 col-sm-6">
                                <a t-attf-href="/shop/{{ p.id }}" style="text-decoration:none; color:inherit; display:block; height:100%;">
                                    <div class="product-card">
                                        <div class="product-img-wrap">
                                            <div class="product-badge">New</div>
                                            <t t-if="p.image_512">
                                                <img t-attf-src="/web/image/product.template/{{ p.id }}/image_512" class="product-img" t-att-alt="p.name"/>
                                            </t>
                                            <t t-else="">
                                                <div style="width:100%; height:280px; display:flex; align-items:center; justify-content:center; font-size:3rem; color:#ccc;">
                                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.47a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.47a2 2 0 0 0-1.34-2.23z"></path></svg>
                                                </div>
                                            </t>
                                        </div>
                                        <div class="product-info">
                                            <t t-if="p.designer_id">
                                                <span class="product-designer">
                                                    <t t-esc="p.designer_id.name"/>
                                                </span>
                                            </t>
                                            <div class="product-title">
                                                <t t-esc="p.name"/>
                                            </div>
                                            <div class="product-price-row">
                                                <span class="product-price">
                                                    <t t-esc="p.list_price" t-options='{"widget":"monetary","display_currency":p.currency_id}'/>
                                                </span>
                                                <span class="product-action">
                                                    Discover <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </t>
                        <t t-if="not new_arrivals">
                            <div class="col-12 text-center text-muted" style="font-size:1.1rem; padding:40px 0;">
                                No products published yet. Check back soon!
                            </div>
                        </t>
                    </div>
                    <div class="text-center mt-5">
                        <a href="/consignment/shop" class="btn-primary-custom" style="padding: 14px 40px; border-radius:30px;">
                            View All Products
                        </a>
                    </div>
                </div>
            </section>

        </div>
    </t>
</template>

<!-- ═══════════════════════════════════════════════════════════════════════
     CONSIGNMENT SHOP PAGE  —  /consignment/shop
     ═══════════════════════════════════════════════════════════════════════ -->
<template id="website_consignment_shop" name="Consignment Shop">
    <t t-call="website.layout">
        <div id="wrap">
            <div class="container py-5">

                <!-- Page Header -->
                <div style="margin-bottom:32px;">
                    <h1 style="font-weight:800;color:#1E2761;">Consignment Shop</h1>
                    <p style="color:#6B7280;">
                        <t t-esc="shop_pager['total']"/> products available
                        <t t-if="selected_designer">
                            from <strong><t t-esc="selected_designer.name"/></strong>
                        </t>
                    </p>
                </div>

                <div class="row">

                    <!-- Sidebar Filters -->
                    <div class="col-lg-3 mb-4">

                        <!-- Search Box -->
                        <form method="GET" action="/consignment/shop">
                            <div style="display:flex;margin-bottom:20px;">
                                <input type="text" name="search"
                                       t-att-value="search"
                                       placeholder="Search products..."
                                       style="flex:1;padding:10px 14px;border:1px solid #e5e7eb;
                                              border-radius:8px 0 0 8px;outline:none;"/>
                                <button type="submit"
                                        style="background:#1E2761;color:#fff;border:none;
                                               padding:10px 16px;border-radius:0 8px 8px 0;
                                               cursor:pointer;">🔍</button>
                            </div>
                        </form>

                        <!-- Filter by Designer -->
                        <div style="background:#fff;border-radius:12px;padding:20px;
                                    box-shadow:0 2px 8px rgba(0,0,0,0.06);margin-bottom:20px;">
                            <h6 style="font-weight:700;color:#1E2761;margin-bottom:14px;">
                                By Designer
                            </h6>
                            <a href="/consignment/shop"
                               t-attf-style="display:block;padding:6px 0;text-decoration:none;
                                             font-weight:{{ 'bold' if not selected_designer else 'normal' }};
                                             color:{{ '#1E2761' if not selected_designer else '#6B7280' }};">
                                All Designers
                            </a>
                            <t t-foreach="all_designers" t-as="d">
                                <a t-attf-href="/consignment/shop?designer_id={{ d.id }}"
                                   t-attf-style="display:block;padding:6px 0;
                                                 text-decoration:none;
                                                 font-weight:{{ 'bold' if selected_designer and selected_designer.id == d.id else 'normal' }};
                                                 color:{{ '#1E2761' if selected_designer and selected_designer.id == d.id else '#374151' }};">
                                    <t t-esc="d.name"/>
                                    <span style="color:#9CA3AF;font-size:0.8rem;margin-left:4px;">
                                        (<t t-esc="d.website_product_count"/>)
                                    </span>
                                </a>
                            </t>
                        </div>

                        <!-- Filter by Category -->
                        <div style="background:#fff;border-radius:12px;padding:20px;
                                    box-shadow:0 2px 8px rgba(0,0,0,0.06);">
                            <h6 style="font-weight:700;color:#1E2761;margin-bottom:14px;">
                                By Category
                            </h6>
                            <a href="/consignment/shop"
                               t-attf-style="display:block;padding:6px 0;text-decoration:none;
                                             color:{{ '#1E2761' if not selected_category else '#6B7280' }};
                                             font-weight:{{ 'bold' if not selected_category else 'normal' }};">
                                All Categories
                            </a>
                            <t t-foreach="categories" t-as="cat">
                                <a t-attf-href="/consignment/shop?category={{ cat[0] }}"
                                   t-attf-style="display:block;padding:6px 0;
                                                 text-decoration:none;
                                                 color:{{ '#1E2761' if selected_category == cat[0] else '#374151' }};
                                                 font-weight:{{ 'bold' if selected_category == cat[0] else 'normal' }};">
                                    <t t-esc="cat[1]"/>
                                </a>
                            </t>
                        </div>

                        <!-- CTA: Sell with us -->
                        <div style="margin-top:20px; background:linear-gradient(135deg, #1E2761, #2D3142); border-radius:12px; padding:24px 20px; text-align:center; color:#fff; box-shadow:0 10px 25px rgba(30, 39, 97, 0.2);">
                            <div style="font-size:2rem; margin-bottom:10px;">✨</div>
                            <h6 style="font-weight:800; margin-bottom:10px; font-size:1.1rem;">Are you a Creator?</h6>
                            <p style="font-size:0.9rem; color:rgba(255,255,255,0.8); margin-bottom:20px; line-height:1.5;">
                                Join our network. Submit your inventory right now to sell it in our shop.
                            </p>
                            <a href="/my/submissions/new" style="display:inline-block; background:#EF8354; color:#fff; padding:12px 24px; border-radius:30px; text-decoration:none; font-weight:700; font-size:0.95rem; width:100%; box-shadow:0 4px 15px rgba(239, 131, 84, 0.4);">
                                Submit Product
                            </a>
                        </div>

                    </div>

                    <!-- Product Grid -->
                    <div class="col-lg-9">
                        <div class="row">
                            <t t-foreach="products" t-as="p">
                                <div class="col-lg-4 col-md-6 mb-4">
                                    <div class="consignment-card">
                                        <!-- Product Image -->
                                        <div style="position:relative;">
                                            <t t-if="p.image_512">
                                                <img t-attf-src="/web/image/product.template/{{ p.id }}/image_512"
                                                     style="width:100%;height:240px;object-fit:cover;"
                                                     t-att-alt="p.name"/>
                                            </t>
                                            <t t-else="">
                                                <div style="width:100%;height:240px;background:#f3f4f6;
                                                            display:flex;align-items:center;
                                                            justify-content:center;font-size:3rem;">
                                                    👗
                                                </div>
                                            </t>
                                            <!-- Category Badge -->
                                            <t t-if="p.consignment_category">
                                                <span style="position:absolute;top:10px;left:10px;
                                                             background:rgba(30,39,97,0.85);
                                                             color:#fff;font-size:0.7rem;
                                                             padding:3px 10px;border-radius:20px;">
                                                    <t t-esc="dict(categories).get(p.consignment_category, '')"/>
                                                </span>
                                            </t>
                                        </div>

                                        <!-- Product Info -->
                                        <div style="padding:16px;">
                                            <!-- Designer Tag -->
                                            <t t-if="p.designer_id">
                                                <a t-attf-href="/designers/{{ p.designer_id.id }}"
                                                   style="font-size:0.72rem;background:#EEF3FF;
                                                          color:#1E2761;padding:2px 10px;
                                                          border-radius:20px;font-weight:600;
                                                          text-decoration:none;">
                                                    <t t-esc="p.designer_id.name"/>
                                                </a>
                                            </t>

                                            <div style="font-weight:600;font-size:0.95rem;
                                                        margin-top:10px;color:#111827;">
                                                <t t-esc="p.name"/>
                                            </div>

                                            <div style="display:flex;justify-content:space-between;
                                                        align-items:center;margin-top:10px;">
                                                <span style="font-weight:700;font-size:1.05rem;
                                                             color:#1E2761;">
                                                    <t t-esc="p.list_price"
                                                       t-options='{"widget":"monetary","display_currency":p.currency_id}'/>
                                                </span>
                                                <a t-attf-href="/shop/{{ p.id }}"
                                                   style="background:#1E2761;color:#fff;
                                                          padding:7px 16px;border-radius:20px;
                                                          text-decoration:none;font-size:0.82rem;
                                                          font-weight:600;">
                                                    View
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>

                            <t t-if="not products">
                                <div class="col-12 text-center py-5">
                                    <div style="font-size:3rem;">🔍</div>
                                    <h5 style="color:#6B7280;margin-top:16px;">
                                        No products found matching your filters.
                                    </h5>
                                    <a href="/consignment/shop" style="color:#1E2761;">
                                        Clear filters
                                    </a>
                                </div>
                            </t>
                        </div>

                        <!-- Pagination -->
                        <t t-if="shop_pager['page_count'] > 1">
                            <div style="display:flex;justify-content:center;
                                        gap:8px;margin-top:32px;">
                                <t t-foreach="range(1, shop_pager['page_count']+1)" t-as="pg">
                                    <a t-attf-href="/consignment/shop?page={{ pg }}"
                                       t-attf-style="padding:8px 14px;border-radius:8px;
                                                     text-decoration:none;
                                                     background:{{ '#1E2761' if pg == shop_pager['page'] else '#f3f4f6' }};
                                                     color:{{ '#fff' if pg == shop_pager['page'] else '#374151' }};
                                                     font-weight:600;">
                                        <t t-esc="pg"/>
                                    </a>
                                </t>
                            </div>
                        </t>

                    </div>
                </div>
            </div>
        </div>
    </t>
</template>

</odoo>
