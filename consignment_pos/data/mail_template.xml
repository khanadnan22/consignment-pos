<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template 1: Settlement Posted notification to designer -->
    <record id="email_template_settlement_posted" model="mail.template">
        <field name="name">Settlement Posted — Designer Notification</field>
        <field name="model_id" ref="model_settlement_record"/>
        <field name="subject">Your Consignment Settlement is Ready — {{ object.period_start }} to {{ object.period_end }}</field>
        <field name="email_from">{{ object.env.company.email or '' }}</field>
        <field name="email_to">{{ object.designer_id.email }}</field>
        <field name="body_html"><![CDATA[
<div style="font-family:Arial,sans-serif;max-width:600px;margin:auto;padding:24px;border:1px solid #e0e0e0;border-radius:6px;">
    <div style="background:#1E2761;padding:16px;border-radius:4px 4px 0 0;">
        <h2 style="color:#fff;margin:0;">Consignment Settlement Statement</h2>
    </div>
    <div style="padding:20px;">
        <p>Dear <strong>{{ object.designer_id.name }}</strong>,</p>
        <p>Your consignment settlement for
           <strong>{{ object.period_start }}</strong> to
           <strong>{{ object.period_end }}</strong>
           has been posted and is now ready.</p>
        <table style="width:100%;border-collapse:collapse;margin:20px 0;">
            <tr style="background:#f3f4f6;">
                <td style="padding:10px;border:1px solid #e5e7eb;"><strong>Total Sales</strong></td>
                <td style="padding:10px;border:1px solid #e5e7eb;text-align:right;">{{ '%.2f' % object.total_sales }}</td>
            </tr>
            <tr>
                <td style="padding:10px;border:1px solid #e5e7eb;">Store Commission</td>
                <td style="padding:10px;border:1px solid #e5e7eb;text-align:right;color:#991B1B;">- {{ '%.2f' % object.commission_amount }}</td>
            </tr>
            <tr style="font-weight:bold;background:#f0fdf4;">
                <td style="padding:10px;border:1px solid #e5e7eb;">Net Payout to You</td>
                <td style="padding:10px;border:1px solid #e5e7eb;text-align:right;color:#166534;">{{ '%.2f' % object.payout_amount }}</td>
            </tr>
        </table>
        <p>You can view your full settlement statement in your designer portal.</p>
        <p>Regards,<br/><strong>{{ object.env.company.name }}</strong></p>
    </div>
</div>
        ]]></field>
    </record>

    <!-- Template 2: Low Stock Alert to admin -->
    <record id="email_template_low_stock" model="mail.template">
        <field name="name">Low Stock Alert — Consignment Product</field>
        <field name="model_id" ref="model_product_template"/>
        <field name="subject">Low Stock Alert: {{ object.name }} ({{ object.qty_available }} left)</field>
        <field name="email_from">{{ object.env.company.email or '' }}</field>
        <field name="email_to">{{ object.env.company.email or '' }}</field>
        <field name="body_html"><![CDATA[
<div style="font-family:Arial,sans-serif;max-width:600px;margin:auto;padding:24px;
            border:1px solid #FED7AA;border-radius:6px;background:#FFFBF5;">
    <div style="background:#D97706;padding:16px;border-radius:4px 4px 0 0;">
        <h2 style="color:#fff;margin:0;">Low Stock Alert</h2>
    </div>
    <div style="padding:20px;">
        <p>The following consignment product has reached its low stock threshold:</p>
        <table style="width:100%;border-collapse:collapse;margin:16px 0;">
            <tr style="background:#FEF3C7;">
                <td style="padding:10px;border:1px solid #FDE68A;"><b>Product</b></td>
                <td style="padding:10px;border:1px solid #FDE68A;">{{ object.name }}</td>
            </tr>
            <tr>
                <td style="padding:10px;border:1px solid #FDE68A;"><b>Designer</b></td>
                <td style="padding:10px;border:1px solid #FDE68A;">
                    {{ object.designer_id.name if object.designer_id else 'N/A' }}
                </td>
            </tr>
            <tr style="background:#FEF3C7;">
                <td style="padding:10px;border:1px solid #FDE68A;"><b>Stock Remaining</b></td>
                <td style="padding:10px;border:1px solid #FDE68A;color:#DC2626;font-weight:bold;">
                    {{ object.qty_available }} units
                </td>
            </tr>
            <tr>
                <td style="padding:10px;border:1px solid #FDE68A;"><b>Alert Threshold</b></td>
                <td style="padding:10px;border:1px solid #FDE68A;">
                    {{ object.low_stock_threshold }} units
                </td>
            </tr>
        </table>
        <p>Please contact the designer to arrange restocking or remove the product
           from the website if out of stock.</p>
        <p>Regards,<br/><b>{{ object.env.company.name }} — Consignment System</b></p>
    </div>
</div>
        ]]></field>
    </record>

</odoo>
