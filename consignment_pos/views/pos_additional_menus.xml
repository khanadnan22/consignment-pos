<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom action for Quotations inside POS -->
    <record id="action_pos_sale_quotations" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_my_quotation': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new quotation, the first step of a new sale!
            </p>
        </field>
    </record>

    <!-- Menu for Quotations under POS root -->
    <menuitem id="menu_pos_sale_quotations"
              name="Quotations"
              parent="point_of_sale.menu_point_root"
              action="action_pos_sale_quotations"
              sequence="26"/>

</odoo>
