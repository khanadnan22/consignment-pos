<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for Online Consignment Orders -->
    <record id="action_consignment_sale_orders" model="ir.actions.act_window">
        <field name="name">Online Orders</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('has_consignment', '=', True)]</field>
    </record>

    <!-- Action for Customer Payments -->
    <record id="action_consignment_payments" model="ir.actions.act_window">
        <field name="name">Payments</field>
        <field name="res_model">account.payment</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('partner_type', '=', 'customer')]</field>
        <field name="context">{'default_partner_type': 'customer'}</field>
    </record>

    <!-- Action for POS Orders -->
    <record id="action_consignment_pos_orders" model="ir.actions.act_window">
        <field name="name">POS Orders</field>
        <field name="res_model">pos.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('has_consignment', '=', True)]</field>
    </record>

    <!-- Action for POS Payments -->
    <record id="action_consignment_pos_payments" model="ir.actions.act_window">
        <field name="name">POS Payments</field>
        <field name="res_model">pos.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_consignment_orders_root" name="Orders &amp; Payments" parent="menu_consignment_root" sequence="15"/>
    
    <menuitem id="menu_consignment_online_orders" name="Online Orders"
              parent="menu_consignment_orders_root"
              action="action_consignment_sale_orders" sequence="10"/>

    <menuitem id="menu_consignment_pos_orders" name="POS Orders"
              parent="menu_consignment_orders_root"
              action="action_consignment_pos_orders" sequence="20"/>

    <menuitem id="menu_consignment_payments" name="Online Payments"
              parent="menu_consignment_orders_root"
              action="action_consignment_payments" sequence="30"/>

    <menuitem id="menu_consignment_pos_payments" name="POS Payments"
              parent="menu_consignment_orders_root"
              action="action_consignment_pos_payments" sequence="40"/>

</odoo>
